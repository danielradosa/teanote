---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const title = post.data.title;
const description = post.data.description;
const canonical = `https://teanote.xyz/blog/${post.slug}`;
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head">
    <meta property="og:type" content="article" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={post.data.heroImage ? `https://teanote.xyz${post.data.heroImage}` : 'https://teanote.xyz/img/og_teanote.jpg'} />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CPMZ66BNG7"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CPMZ66BNG7');
    </script>

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        "headline": ${JSON.stringify(title)},
        "description": ${JSON.stringify(description)},
        "datePublished": ${JSON.stringify(post.data.pubDate.toISOString())},
        "author": {"@type": "Person", "name": "Daniel Radosa"},
        "url": ${JSON.stringify(canonical)}
      }
    </script>
  </Fragment>

  <Header />

  <main class="mx-auto max-w-3xl px-4">
    <article class="py-14 md:py-20">
      <a href="/blog" class="text-sm font-extrabold text-[#898565] hover:underline">← Back to blog</a>

      <h1 class="mt-4 text-4xl font-extrabold tracking-tight md:text-5xl">{title}</h1>
      <p class="mt-4 text-lg text-zinc-700">{description}</p>

      <div class="mt-6 text-sm font-semibold text-zinc-600">
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
        </time>
        {post.data.tags?.length ? <span class="text-zinc-400"> &mdash; {post.data.tags.join(', ')}</span> : null}
      </div>

      <div class="prose prose-zinc mt-10 max-w-none prose-h2:font-extrabold prose-h3:font-extrabold prose-a:text-[#898565]">
        <Content />
      </div>

      <div class="mt-10 flex flex-wrap gap-2">
        {post.data.tags?.map((t) => (
          <span class="rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs font-extrabold text-zinc-700">
            #{t}
          </span>
        ))}
      </div>

      <!-- Related posts -->
      <div class="mt-10">
        <h2 class="text-2xl font-extrabold">Related posts</h2>
        <p class="mt-2 text-zinc-700">More guides you might like.</p>

        <div class="mt-5 grid gap-4 md:grid-cols-2">
          {(await getCollection('blog'))
            .filter((p) => p.slug !== post.slug)
            .map((p) => ({
              post: p,
              score:
                (p.data.tags ?? []).filter((tag) => (post.data.tags ?? []).includes(tag)).length,
            }))
            .filter((x) => x.score > 0)
            .sort((a, b) => {
              if (b.score !== a.score) return b.score - a.score;
              return b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf();
            })
            .slice(0, 4)
            .map(({ post: p }) => (
              <a
                href={`/blog/${p.slug}`}
                class="tilt-card block rounded-2xl border border-zinc-200 bg-white p-5 shadow-sm transition hover:shadow-md"
              >
                <div class="text-sm font-semibold text-zinc-600">
                  {p.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}
                </div>
                <div class="mt-2 text-lg font-extrabold hover:text-[#898565] transition">{p.data.title}</div>
                <div class="mt-2 text-sm text-zinc-700">{p.data.description}</div>
              </a>
            ))}
        </div>
      </div>

      <div class="mt-12 rounded-2xl border border-[#898565]/40 bg-gradient-to-br from-[#bdb695]/15 to-white p-7">
        <h2 class="text-2xl font-extrabold">Try Teanote</h2>
        <p class="mt-2 text-zinc-700">Teanote is a mindful tea journal + gongfu timer with cross-device sync. No download needed.</p>
        <div class="mt-5">
          <Button href="https://app.teanote.xyz" variant="primary">Start your 30-day free trial</Button>
        </div>
      </div>
    </article>
  </main>

  <Footer />
</Layout>
