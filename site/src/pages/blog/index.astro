---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Teanote Blog | Tea Journal & Gongfu Timer Guides';
const description = 'Practical guides on tea tasting notes, gongfu timing, and keeping a mindful tea journal.';
---

<Layout title={title} description={description} canonical="https://teanote.xyz/blog">
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="Teanote Blog RSS" href="https://teanote.xyz/blog/rss.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://teanote.xyz/blog" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://teanote.xyz/img/og_teanote.jpg" />

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CPMZ66BNG7"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-CPMZ66BNG7');
    </script>

    <!-- Structured Data (Blog + posts) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Blog",
        "name": "Teanote Blog",
        "url": "https://teanote.xyz/blog",
        "description": "Guides and updates for Teanote &mdash; a mindful tea journal and gongfu timer.",
        "blogPost": [
          ${posts
            .map(
              (p) => `{
            "@type": "BlogPosting",
            "headline": ${JSON.stringify(p.data.title)},
            "datePublished": ${JSON.stringify(p.data.pubDate.toISOString())},
            "url": ${JSON.stringify(`https://teanote.xyz/blog/${p.slug}`)},
            "author": {"@type": "Person", "name": "Daniel Radosa"}
          }`
            )
            .join(',')}
        ]
      }
    </script>
  </Fragment>

  <Header />

  <main class="mx-auto max-w-6xl px-4">
    <section class="py-14 md:py-20">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight md:text-5xl">Blog</h1>
        <p class="mt-4 text-lg text-zinc-700 md:text-xl">{description}</p>

        <div class="mt-6 flex justify-center">
          <a
            href="/blog/rss.xml"
            class="inline-flex items-center gap-2 rounded-full border border-[#898565]/50 bg-[#bdb695]/15 px-4 py-2 text-sm font-extrabold text-zinc-900 hover:text-[#898565] transition"
            style="width: max-content;"
          >
            RSS <span class="font-semibold text-zinc-700">/blog/rss.xml</span>
          </a>
        </div>
      </div>

      <div class="mt-10 grid gap-6 md:grid-cols-2">
        {posts.map((post) => (
          <a
            href={`/blog/${post.slug}`}
            class="tilt-card group block rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm transition hover:shadow-md cursor-pointer"
          >
            <div class="text-sm font-semibold text-zinc-600">
              <time datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}
              </time>
              {post.data.tags?.length ? (
                <span class="text-zinc-400"> &mdash; {post.data.tags.join(', ')}</span>
              ) : null}
            </div>

            <h2 class="mt-3 text-2xl font-extrabold tracking-tight group-hover:text-[#898565] transition">
              {post.data.title}
            </h2>
            <p class="mt-3 text-zinc-700">{post.data.description}</p>

            <div class="mt-5 inline-flex items-center gap-2 text-sm font-extrabold text-[#898565]">
              Read <span class="transition group-hover:translate-x-0.5">→</span>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <Footer />
</Layout>
