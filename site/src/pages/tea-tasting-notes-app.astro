---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Button from '../components/Button.astro';

const title = 'Tea Tasting Notes App | Teanote';
const description = 'Log tea tasting notes (aroma, taste, aftertaste, energy) and connect them to real brew sessions. A calm tea tasting notes app with cross-device sync.';
---

<Layout title={title} description={description} canonical="https://teanote.xyz/tea-tasting-notes-app">
  <Header />

  <main class="mx-auto max-w-6xl px-4">
    <section class="py-16 md:py-24">
      <div class="mx-auto max-w-3xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight md:text-6xl">A tea tasting notes app for people who taste carefully</h1>
        <p class="mt-5 text-lg text-zinc-700 md:text-xl">Capture better notes, revisit them, and learn what you actually like.</p>
        <div class="mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <Button href="https://app.teanote.xyz/signup" variant="primary" data-track="cta_tasting_notes_signup">Start your 30-day free trial</Button>
          <a class="text-sm font-extrabold text-[#898565] hover:underline" href="/blog/how-to-write-tea-tasting-notes">How to write tea tasting notes →</a>
        </div>
      </div>

      <div class="mt-12 grid gap-6 md:grid-cols-3">
        <div class="tilt-card rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-extrabold">Structured prompts (but flexible)</h2>
          <p class="mt-3 text-zinc-700">Write freeform notes, or use structure when you want consistency.</p>
        </div>
        <div class="tilt-card rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-extrabold">Connected to real brewing</h2>
          <p class="mt-3 text-zinc-700">Your tasting notes make more sense when they’re tied to a session and infusions.</p>
        </div>
        <div class="tilt-card rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm">
          <h2 class="text-xl font-extrabold">Search & compare</h2>
          <p class="mt-3 text-zinc-700">Over time you build a personal reference: teas, sessions, and what changed.</p>
        </div>
      </div>
    </section>

    <section class="py-12 md:py-16">
      <div class="mx-auto max-w-3xl rounded-2xl border border-zinc-200 bg-white p-7 shadow-sm">
        <h2 class="text-2xl font-extrabold">If you only do one thing</h2>
        <p class="mt-2 text-zinc-700">After every session, write 1–2 sentences on: what surprised you, and what you’d change next time.</p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
