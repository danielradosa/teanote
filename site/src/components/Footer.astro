---
const formAction = import.meta.env.PUBLIC_FORMSPREE_ENDPOINT ?? 'https://formspree.io/f/your_form_id';
---

<footer class="mt-16 border-t border-zinc-200 py-12">
  <div class="mx-auto max-w-6xl px-4 text-center">
    <h2 class="text-2xl font-extrabold">Who decided to do this?</h2>
    <p class="mt-3 text-lg text-zinc-700">
      Developed by self-proclaimed digital alchemist,
      <a class="font-bold text-zinc-900 hover:text-[#898565]" href="https://danielradosa.com">Daniel Radosa</a>,
      based in Slovakia.
    </p>

    <div class="mt-6 flex flex-col items-center justify-center gap-3 text-sm font-semibold text-zinc-700 md:flex-row md:gap-8">
      <a class="hover:text-[#898565]" href="https://docs.teanote.xyz/terms">Terms of Use</a>
      <a class="hover:text-[#898565]" href="https://docs.teanote.xyz/privacy">Privacy Policy</a>
      <a class="hover:text-[#898565]" href="https://docs.teanote.xyz/cookies">Cookies</a>
      <a class="hover:text-[#898565]" href="/blog/rss.xml">RSS / Newsletter</a>
      <button class="cursor-pointer hover:text-[#898565]" data-contact-open data-track="contact_open_footer" type="button">Contact form</button>
      <a class="hover:text-[#898565]" href="mailto:info@teanote.xyz">info@teanote.xyz</a>
    </div>

    <div class="mt-6 text-sm text-zinc-500">© Teanote 2026</div>
  </div>
</footer>

<div class="contact-modal" data-contact-modal hidden>
  <div class="contact-backdrop" data-contact-close></div>
  <div class="contact-panel">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="text-xl font-extrabold">Send us a message</h3>
        <p class="mt-1 text-sm text-zinc-600">The enquiry will go directly to our mailbox. Response rate is ~24 hours.</p>
      </div>
      <button class="text-zinc-500 hover:text-zinc-900 hover:cursor-pointer" type="button" data-contact-close aria-label="Close">✕</button>
    </div>

    <form class="mt-5 space-y-3" action={formAction} method="POST" data-track-submit="contact_submit_formspree">
      <input type="hidden" name="_subject" value="New message from teanote.xyz" />
      <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

      <label class="block text-left text-sm font-semibold text-zinc-700">
        Name
        <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2" type="text" name="name" required />
      </label>

      <label class="block text-left text-sm font-semibold text-zinc-700">
        Email
        <input class="mt-1 w-full rounded-lg border border-zinc-300 px-3 py-2" type="email" name="email" required />
      </label>

      <label class="block text-left text-sm font-semibold text-zinc-700">
        Message
        <textarea class="mt-1 min-h-32 w-full rounded-lg border border-zinc-300 px-3 py-2" name="message" required></textarea>
      </label>

      <div class="flex gap-3 pt-1">
        <button class="rounded-full bg-[#202121] px-5 py-2 text-sm font-extrabold text-white hover:bg-black" type="submit">Send</button>
        <button class="rounded-full border border-zinc-300 px-5 py-2 text-sm font-extrabold" type="button" data-contact-close>Cancel</button>
      </div>
    </form>
  </div>
</div>

<script>
  const modal = document.querySelector('[data-contact-modal]');
  const opens = document.querySelectorAll('[data-contact-open]');
  const closes = document.querySelectorAll('[data-contact-close]');

  const openModal = () => {
    if (!modal) return;
    modal.hidden = false;
    document.body.classList.add('modal-open');
  };

  const closeModal = () => {
    if (!modal) return;
    modal.hidden = true;
    document.body.classList.remove('modal-open');
  };

  opens.forEach((el) => el.addEventListener('click', openModal));
  closes.forEach((el) => el.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });
</script>
